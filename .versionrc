{
  "tagPrefix": "",
  "skip": {
    "bump": true,
    "changelog": true
  },
  "types": [
    {
      "type": "chore",
      "hidden": true
    },
    {
      "type": "docs",
      "hidden": true
    },
    {
      "type": "feat",
      "section": "Features"
    },
    {
      "type": "fix",
      "section": "Bug Fixes"
    },
    {
      "type": "refactor",
      "section": "Tweaks"
    }
  ],
  "releaseCommitMessageFormat": "release: {{currentTag}}\n\n[skip ci]"
}
